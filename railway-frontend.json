{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/cryptexa-admin run build"
  },
  "deploy": {
    "startCommand": "npx serve -s artifacts/cryptexa-admin/dist -l ${PORT:-3000}",
    "restartPolicyType": "ON_FAILURE"
  }
}
